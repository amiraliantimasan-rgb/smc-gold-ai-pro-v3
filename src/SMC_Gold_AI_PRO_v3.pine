
//============================
// v1.1 ENHANCEMENTS
//============================

// SESSION FILTER
useSessionFilter = input.bool(false, "Use Session Filter")
londonSession = input.session("0700-1100", "London Session")
nySession = input.session("1300-1700", "New York Session")

inLondon = not na(time(timeframe.period, londonSession))
inNY = not na(time(timeframe.period, nySession))

tradeAllowed = not useSessionFilter or inLondon or inNY

// RISK MANAGEMENT DISPLAY
riskPercent = input.float(1.0, "Risk %", minval=0.1, step=0.1)

riskValueLong = strongBuy and tradeAllowed ? (close - lastLow) * riskPercent : na
riskValueShort = strongSell and tradeAllowed ? (lastHigh - close) * riskPercent : na

// DASHBOARD
var table dash = table.new(position.top_right, 2, 6, border_width=1)

if bar_index % 5 == 0
    table.cell(dash, 0, 0, "SMC AI v1.1", text_color=color.white, bgcolor=color.black)
    table.cell(dash, 1, 0, "ACTIVE", text_color=color.lime, bgcolor=color.black)

    table.cell(dash, 0, 1, "Trend")
    table.cell(dash, 1, 1, str.tostring(trend))

    table.cell(dash, 0, 2, "Buy Score")
    table.cell(dash, 1, 2, str.tostring(bullScore))

    table.cell(dash, 0, 3, "Sell Score")
    table.cell(dash, 1, 3, str.tostring(bearScore))

    table.cell(dash, 0, 4, "Session")
    table.cell(dash, 1, 4, inLondon ? "London" : inNY ? "NY" : "Off")

    table.cell(dash, 0, 5, "Trade")
    table.cell(dash, 1, 5, tradeAllowed ? "YES" : "NO")
