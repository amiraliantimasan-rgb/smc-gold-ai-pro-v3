//@version=6
indicator("SMC Gold AI PRO v3 - v0.6 FVG Engine", overlay=true, max_labels_count=500, max_boxes_count=500)

//============================
// INPUTS
//============================
len = input.int(2, "Swing Sensitivity", minval=1)
showSwings = input.bool(true)
showLiquidity = input.bool(true)
showSweep = input.bool(true)
showDisplacement = input.bool(true)
showStructure = input.bool(true)
showFVG = input.bool(true)

//============================
// CORE CALCULATIONS
//============================
atr = ta.atr(14)
body = math.abs(close - open)

//============================
// SWING ENGINE
//============================
swingHigh = high[len] == ta.highest(high, len * 2 + 1)
swingLow  = low[len] == ta.lowest(low, len * 2 + 1)

// STORAGE
var float[] swingHighs = array.new_float()
var float[] swingLows  = array.new_float()
var int trend = 0

//============================
// SWINGS
//============================
if swingHigh
    sh = high[len]
    array.push(swingHighs, sh)
    if showSwings
        label.new(bar_index - len, sh, "SH", style=label.style_label_down, color=color.gray)

if swingLow
    sl = low[len]
    array.push(swingLows, sl)
    if showSwings
        label.new(bar_index - len, sl, "SL", style=label.style_label_up, color=color.gray)

//============================
// LIQUIDITY
//============================
lastHigh = array.size(swingHighs) > 0 ? array.get(swingHighs, array.size(swingHighs)-1) : na
lastLow  = array.size(swingLows) > 0 ? array.get(swingLows, array.size(swingLows)-1) : na

if showLiquidity and not na(lastHigh)
    line.new(bar_index-1, lastHigh, bar_index, lastHigh, extend=extend.right, color=color.red)

if showLiquidity and not na(lastLow)
    line.new(bar_index-1, lastLow, bar_index, lastLow, extend=extend.right, color=color.green)

//============================
// LIQUIDITY SWEEP
//============================
buySweep  = not na(lastHigh) and high > lastHigh and close < lastHigh
sellSweep = not na(lastLow) and low < lastLow and close > lastLow

if showSweep and buySweep
    label.new(bar_index, high, "BSL SWEEP", style=label.style_label_down, color=color.red)

if showSweep and sellSweep
    label.new(bar_index, low, "SSL SWEEP", style=label.style_label_up, color=color.lime)

//============================
// DISPLACEMENT
//============================
bullDisp = body > atr * 1.2 and close > lastHigh
bearDisp = body > atr * 1.2 and close < lastLow

if showDisplacement and bullDisp
    label.new(bar_index, high, "BULL DISP", color=color.green)

if showDisplacement and bearDisp
    label.new(bar_index, low, "BEAR DISP", color=color.red)

//============================
// MARKET STRUCTURE
//============================
bullBreak = not na(lastHigh) and close > lastHigh
bearBreak = not na(lastLow) and close < lastLow

if showStructure and bullBreak
    label.new(bar_index, high, trend == -1 ? "CHoCH ↑" : "BOS ↑", color=color.lime)
    trend := 1

if showStructure and bearBreak
    label.new(bar_index, low, trend == 1 ? "CHoCH ↓" : "BOS ↓", color=color.red)
    trend := -1

//============================
// FVG ENGINE (NO REPAINT)
//============================
fvgBull = low > high[2]
fvgBear = high < low[2]

if showFVG and fvgBull
    box.new(bar_index-2, high[2], bar_index, low, border_color=color.green, bgcolor=color.new(color.green, 85))

if showFVG and fvgBear
    box.new(bar_index-2, low[2], bar_index, high, border_color=color.red, bgcolor=color.new(color.red, 85))

//============================
// DEBUG
//============================
plotchar(swingHigh, "SH", "▼", location=location.abovebar)
plotchar(swingLow, "SL", "▲", location=location.belowbar)