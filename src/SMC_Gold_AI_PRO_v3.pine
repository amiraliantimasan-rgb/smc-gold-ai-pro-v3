//@version=5
indicator("SMC Gold AI PRO v3 - v0.5 Market Structure Engine", overlay=true, max_labels_count=500)

//============================
// v0.5 - MARKET STRUCTURE ENGINE (SMC LAYER)
// Built on v0.4 Displacement Engine
//============================

// Inputs
len = input.int(2, "Swing Sensitivity (NO PIVOT)", minval=1)
showSwings = input.bool(true, "Show Swings")
showLiquidity = input.bool(true, "Show Liquidity")
showSweep = input.bool(true, "Show Sweep")
showDisplacement = input.bool(true, "Show Displacement")
showStructure = input.bool(true, "Show BOS/CHoCH")
eqThreshold = input.float(0.1, "EQH/EQL ATR Tolerance")

atr = ta.atr(14)
body = math.abs(close - open)

//============================
// SWING ENGINE (NO PIVOT)
//============================
swingHigh = high[len] == ta.highest(high, len * 2 + 1)
swingLow  = low[len]  == ta.lowest(low, len * 2 + 1)

//============================
// STORAGE
//============================
var float[] swingHighs = array.new_float()
var float[] swingLows  = array.new_float()
var int trend = 0

//============================
// SWING PROCESS
//============================
if swingHigh
    float sh = high[len]
    array.push(swingHighs, sh)

    if showSwings
        label.new(bar_index - len, sh, "SH", style=label.style_label_down, color=color.gray)

    if array.size(swingHighs) > 1
        float prevH = array.get(swingHighs, array.size(swingHighs) - 2)
        if math.abs(sh - prevH) <= atr * eqThreshold
            label.new(bar_index - len, sh, "EQH", style=label.style_label_down, color=color.orange, textcolor=color.black)

if swingLow
    float sl = low[len]
    array.push(swingLows, sl)

    if showSwings
        label.new(bar_index - len, sl, "SL", style=label.style_label_up, color=color.gray)

    if array.size(swingLows) > 1
        float prevL = array.get(swingLows, array.size(swingLows) - 2)
        if math.abs(sl - prevL) <= atr * eqThreshold
            label.new(bar_index - len, sl, "EQL", style=label.style_label_up, color=color.aqua, textcolor=color.black)

//============================
// LIQUIDITY LEVELS
//============================
lastHigh = array.size(swingHighs) > 0 ? array.get(swingHighs, array.size(swingHighs)-1) : na
lastLow  = array.size(swingLows) > 0 ? array.get(swingLows, array.size(swingLows)-1) : na

if showLiquidity and not na(lastHigh)
    line.new(bar_index-1, lastHigh, bar_index, lastHigh, extend=extend.right, color=color.red)

if showLiquidity and not na(lastLow)
    line.new(bar_index-1, lastLow, bar_index, lastLow, extend=extend.right, color=color.green)

//============================
// LIQUIDITY SWEEP ENGINE (ICT CORE)
//============================

buySideSweep = not na(lastHigh) and high > lastHigh and close < lastHigh
sellSideSweep = not na(lastLow) and low < lastLow and close > lastLow

if showSweep and buySideSweep
    label.new(bar_index, high, "BSL SWEEP", style=label.style_label_down, color=color.red, textcolor=color.white)

if showSweep and sellSideSweep
    label.new(bar_index, low, "SSL SWEEP", style=label.style_label_up, color=color.lime, textcolor=color.black)

//============================
// DISPLACEMENT ENGINE (ICT MOMENTUM)
//============================

bullDisplacement = body > atr * 1.2 and close > open and close > lastHigh
bearDisplacement = body > atr * 1.2 and close < open and close < lastLow

if showDisplacement and bullDisplacement
    label.new(bar_index, high, "BULL DISP", style=label.style_label_up, color=color.green, textcolor=color.white)

if showDisplacement and bearDisplacement
    label.new(bar_index, low, "BEAR DISP", style=label.style_label_down, color=color.red, textcolor=color.white)

//============================
// MARKET STRUCTURE (BOS / CHoCH)
//============================

bullBreak = not na(lastHigh) and close > lastHigh
bearBreak = not na(lastLow) and close < lastLow

if showStructure and bullBreak
    label.new(bar_index, high, trend == -1 ? "CHoCH ↑" : "BOS ↑", style=label.style_label_up, color=color.lime, textcolor=color.black)
    trend := 1

if showStructure and bearBreak
    label.new(bar_index, low, trend == 1 ? "CHoCH ↓" : "BOS ↓", style=label.style_label_down, color=color.red, textcolor=color.white)
    trend := -1

//============================
// DEBUG SWINGS
//============================
plotchar(swingHigh, "Swing High", "▼", location=location.abovebar, color=color.red)
plotchar(swingLow, "Swing Low", "▲", location=location.belowbar, color=color.lime)