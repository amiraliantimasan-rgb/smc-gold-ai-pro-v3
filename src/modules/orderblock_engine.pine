//============================
// v0.8 REFACTOR - ORDER BLOCK ZONE ENGINE (ICT PRO)
// ICT / SMC GOLD AI PRO v3
//============================

len = input.int(2, "Swing Sensitivity")
atr = ta.atr(14)
body = math.abs(close - open)

// Swing reference (simplified structure base)
swingHigh = high[len] == ta.highest(high, len * 2 + 1)
swingLow  = low[len] == ta.lowest(low, len * 2 + 1)

var float lastHigh = na
var float lastLow  = na

//============================
// STORAGE (ORDER BLOCK ZONES)
//============================
var box[] bullBoxes = array.new_box()
var box[] bearBoxes = array.new_box()

//============================
// UPDATE SWINGS
//============================
if swingHigh
    lastHigh := high[len]
if swingLow
    lastLow := low[len]

//============================
// DISPLACEMENT BASE
//============================
bullDisplacement = body > atr * 1.2 and close > lastHigh
bearDisplacement = body > atr * 1.2 and close < lastLow

//============================
// ORDER BLOCK ZONES (ICT PRO)
//============================

// Bullish OB zone = previous bearish candle
if bullDisplacement and close[1] < open[1]
    float top = high[1]
    float bot = low[1]
    box b = box.new(left=bar_index-1, right=bar_index, top=top, bottom=bot, extend=extend.right, bgcolor=color.new(color.green, 85), border_color=color.green)
    array.push(bullBoxes, b)

// Bearish OB zone = previous bullish candle
if bearDisplacement and close[1] > open[1]
    float top = high[1]
    float bot = low[1]
    box b = box.new(left=bar_index-1, right=bar_index, top=top, bottom=bot, extend=extend.right, bgcolor=color.new(color.red, 85), border_color=color.red)
    array.push(bearBoxes, b)

//============================
// MITIGATION LOGIC
//============================

for i = 0 to array.size(bullBoxes) - 1
    box bx = array.get(bullBoxes, i)
    float top = box.get_top(bx)
    float bot = box.get_bottom(bx)
    if low <= top and high >= bot
        box.set_bgcolor(bx, color.new(color.gray, 85))

for i = 0 to array.size(bearBoxes) - 1
    box bx = array.get(bearBoxes, i)
    float top = box.get_top(bx)
    float bot = box.get_bottom(bx)
    if low <= top and high >= bot
        box.set_bgcolor(bx, color.new(color.gray, 85))
